<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Salary Tracker Pro</title>
    <style>
        :root {
            --primary: #00d2ff;
            --secondary: #3a7bd5;
            --bg: #0f172a;
            --card-bg: rgba(255, 255, 255, 0.05);
            --text: #f8fafc;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            color: var(--text);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

        .container {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 2.5rem;
            border-radius: 24px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            width: 100%;
            max-width: 450px;
            text-align: center;
        }

        h1 {
            font-weight: 300;
            letter-spacing: 1px;
            margin-bottom: 2rem;
            color: var(--primary);
        }

        .input-group {
            margin-bottom: 2rem;
            text-align: left;
        }

        label {
            display: block;
            font-size: 0.85rem;
            margin-bottom: 0.5rem;
            color: #94a3b8;
            text-transform: uppercase;
        }

        input {
            width: 100%;
            padding: 12px;
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 8px;
            color: white;
            font-size: 1.1rem;
            outline: none;
            transition: border-color 0.3s;
            box-sizing: border-box;
        }

        input:focus {
            border-color: var(--primary);
        }

        .display-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
            margin-bottom: 2.5rem;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.03);
            padding: 1.5rem;
            border-radius: 16px;
            border-bottom: 3px solid var(--secondary);
        }

        .stat-label {
            font-size: 0.75rem;
            color: #94a3b8;
            margin-bottom: 5px;
        }

        .stat-value {
            font-family: 'Courier New', monospace;
            font-size: 2.2rem;
            font-weight: bold;
        }

        #money-display {
            color: #4ade80;
        }

        .controls {
            display: flex;
            gap: 1rem;
        }

        button {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            text-transform: uppercase;
            font-size: 0.9rem;
        }

        .btn-start {
            background: linear-gradient(to right, var(--primary), var(--secondary));
            color: white;
        }

        .btn-stop {
            background: #ef4444;
            color: white;
            display: none;
        }

        .btn-reset {
            background: #475569;
            color: white;
        }

        button:hover {
            transform: translateY(-2px);
            filter: brightness(1.1);
        }

        button:active {
            transform: translateY(0);
        }
    </style>
</head>
<body>

<div class="container">
    <h1>Salary Tracker</h1>

    <div class="input-group">
        <label>Valor da sua hora (R$)</label>
        <input type="number" id="hourly-rate" placeholder="Ex: 50.00" step="0.01">
    </div>

    <div class="display-grid">
        <div class="stat-card">
            <div class="stat-label">Tempo Decorrido</div>
            <div id="time-display" class="stat-value">00:00:00</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Ganhos Acumulados</div>
            <div id="money-display" class="stat-value">R$ 0,00</div>
        </div>
    </div>

    <div class="controls">
        <button id="btn-toggle" class="btn-start" onclick="toggleTimer()">Iniciar</button>
        <button class="btn-reset" onclick="resetTimer()">Resetar</button>
    </div>
</div>

<script>
    let seconds = 0;
    let timerInterval = null;
    let hourlyRate = 0;

    function updateDisplay() {
        // Cálculo de Tempo
        const hrs = Math.floor(seconds / 3600);
        const mins = Math.floor((seconds % 3600) / 60);
        const secs = seconds % 60;
        
        const timeString = 
            `${hrs.toString().padStart(2, '0')}:${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
        document.getElementById('time-display').innerText = timeString;

        // Cálculo de Dinheiro
        // (Valor hora / 3600) = Valor por segundo
        const moneyEarned = (hourlyRate / 3600) * seconds;
        document.getElementById('money-display').innerText = 
            moneyEarned.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    }

    function toggleTimer() {
        const btn = document.getElementById('btn-toggle');
        const rateInput = document.getElementById('hourly-rate');

        if (timerInterval) {
            // Parar
            clearInterval(timerInterval);
            timerInterval = null;
            btn.innerText = "Retomar";
            btn.style.background = "linear-gradient(to right, #00d2ff, #3a7bd5)";
            rateInput.disabled = false;
        } else {
            // Iniciar
            hourlyRate = parseFloat(rateInput.value) || 0;
            
            if (hourlyRate <= 0) {
                alert("Por favor, insira um valor de hora válido.");
                return;
            }

            rateInput.disabled = true;
            btn.innerText = "Pausar";
            btn.style.background = "#ef4444";
            
            timerInterval = setInterval(() => {
                seconds++;
                updateDisplay();
            }, 1000);
        }
    }

    function resetTimer() {
        clearInterval(timerInterval);
        timerInterval = null;
        seconds = 0;
        
        const btn = document.getElementById('btn-toggle');
        btn.innerText = "Iniciar";
        btn.style.background = "linear-gradient(to right, #00d2ff, #3a7bd5)";
        
        document.getElementById('hourly-rate').disabled = false;
        updateDisplay();
    }
</script>

</body>
</html>
